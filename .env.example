SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Volitelné: Supabase CLI (npx supabase db push) nebo CI
SUPABASE_ACCESS_TOKEN=
SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Supabase Auth → URL Configuration → Redirect URLs (např. lokálně):
# http://localhost:3000/auth/callback
# http://localhost:3000/auth/reset-password
SUPABASE_STORAGE_BUCKET=agent-artifacts

AZURE_PROXY_BASE_URL=
AZURE_PROXY_API_KEY=
AZURE_PROXY_API_VERSION=2024-12-01-preview
AZURE_PROXY_DEPLOYMENT_ID=models-gpt-54
AZURE_PROXY_MODEL_DEFAULT=
AZURE_PROXY_MODEL_FALLBACK=
AZURE_PROXY_TIMEOUT_MS=30000
AZURE_PROXY_MAX_TOKENS_PER_REQUEST=3000

GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_IMPERSONATED_USER=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Volitelné: veřejná URL aplikace pro OAuth redirect (musí sedět s redirect URI v Google / Entra). Jinak origin z HTTP požadavku.
# NEXT_PUBLIC_APP_URL=https://your-app.example.com
GOOGLE_CALENDAR_ID=primary

# Microsoft 365 (Outlook + kalendář) — volitelné; připojení přes /settings
# MICROSOFT_OAUTH_CLIENT_ID=
# MICROSOFT_OAUTH_CLIENT_SECRET=
# MICROSOFT_OAUTH_TENANT=common

AGENT_MAX_QUERY_ROWS=500
AGENT_QUERY_TIMEOUT_MS=15000

# Volitelné: Bezrealitky GraphQL — výchozí https://api.bezrealitky.cz/graphql/; přepis jen pokud se změní
# BEZREALITKY_GRAPHQL_URL=https://api.bezrealitky.cz/graphql/
# BEZREALITKY_GRAPHQL_QUERY=
# BEZREALITKY_GRAPHQL_OPERATION_NAME=AdvertRelatedList
# BEZREALITKY_GRAPHQL_ORIGIN=https://www.bezrealitky.cz
# BEZREALITKY_GRAPHQL_REFERER=https://www.bezrealitky.cz/
# Výchozí query: listAdverts + regionOsmIds R435514 (Praha). Vlastní BEZREALITKY_GRAPHQL_QUERY musí sedět s variables.
# MARKET_FETCH_USER_AGENT=
TOKEN_ENCRYPTION_KEY=replace_with_long_random_secret

# Stejný secret pro POST /api/cron/daily, /api/cron/purge-audit, /api/cron/scheduled-agent-tasks (hlavička x-cron-secret).
CRON_SECRET=

# BOA-007: čtení trace pro automation_worker (GET /api/agent/trace/ops)
# AUDIT_OPS_SECRET=
# Počet dní pro POST /api/cron/purge-audit (výchozí 90)
# AGENT_TRACE_RETENTION_DAYS=90

# Presentation template (optional). Defaults to assets/presentation-templates/blue-white-company-profile.pptx
# PRESENTATION_TEMPLATE_PATH=
# PRESENTATION_USE_TEMPLATE=   # true | false | unset (unset = use template if file exists)
# PRESENTATION_TEMPLATE_CONTENT_SLIDE_INDEX=13
# PRESENTATION_TEMPLATE_TITLE_SLIDE_INDEX=1
# PRESENTATION_SKIP_PDF=false
# PRESENTATION_DECK_SUBTITLE=Back Office · report
